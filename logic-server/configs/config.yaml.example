# g-video 全局配置文件模板 (示例)
# 使用说明：复制此文件并重命名为 config.yaml，然后填写你的真实信息

# 数据库配置
database:
  # 格式: "用户名:密码@tcp(地址:端口)/数据库名?charset=utf8mb4&parseTime=True&loc=Local"
  dsn: "root:your_password@tcp(127.0.0.1:3306)/g_video?charset=utf8mb4&parseTime=True&loc=Local"

# 阿里云 OSS 配置
oss:
  endpoint: "oss-cn-wuhan-lr.aliyuncs.com" # 对应你图片中的武汉节点
  access_key_id: "YOUR_ACCESS_KEY_ID"      # 填入你的 AccessKey ID
  access_key_secret: "YOUR_ACCESS_KEY_SECRET" # 填入你的 AccessKey Secret
  bucket_name: "g-video-assets"           # 你的 Bucket 名字

# Redis 配置
redis:
  addr: "127.0.0.1:6379"
  password: "" # 如果没设密码留空
  db: 0        # 默认使用 0 号库